{
  "name": "librewallet",
  "version": "1.1.10",
  "description": "Lokalny tracker portfela inwestycyjnego z importem XTB",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "librewallet": "bin/librewallet.js"
  },
  "pkg": {
    "assets": [
      "server.js",
      "i18n.js",
      "app.js",
      "index.html",
      "styles.css",
      "favicon.ico",
      "assets/**/*",
      "vendor/**/*"
    ],
    "outputPath": "dist/desktop"
  },
  "files": [
    "bin",
    "server.js",
    "i18n.js",
    "app.js",
    "index.html",
    "styles.css",
    "favicon.ico",
    "assets",
    "vendor",
    "INSTALL.txt",
    "INSTALL.en.txt",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/librewallet.js",
    "server": "node server.js",
    "build:desktop": "bash scripts/build-desktop.sh",
    "build:desktop:all": "bash scripts/build-desktop.sh all",
    "demo-data": "node scripts/build-demo-xtb-export.mjs"
  },
  "keywords": [
    "portfolio",
    "xtb",
    "investment",
    "tracker"
  ]
}
